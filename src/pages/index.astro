---
/**
 * The whole site is one page: the ops console for a single declared
 * resource. Section order tells the story — what's running now (Systems),
 * how it got here (Lifecycle), what it's capable of (Labels), how to
 * reach it (Contact).
 *
 * All content lives in src/data/resume.ts.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Systems from "../components/Systems.astro";
import Lifecycle from "../components/Lifecycle.astro";
import Labels from "../components/Labels.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <Systems />
    <Lifecycle />
    <Labels />
  </main>
  <Footer />
</BaseLayout>
