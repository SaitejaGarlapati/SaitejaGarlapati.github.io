---
/**
 * Hero: name + summary on the left, a live "Engineer" resource spec on the
 * right — the site's core conceit. The status block carries a real uptime
 * counter ticking since the current role's start date.
 */
import { identity } from "../data/resume";

const base = import.meta.env.BASE_URL;
---

<section id="top" class="mx-auto grid max-w-6xl gap-12 px-5 pb-20 pt-28 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:pt-36">
  <!-- Intro -->
  <div>
    <p class="font-mono text-sm text-console-green">
      $ kubectl describe engineer {identity.handle}
    </p>
    <h1 class="mt-4 font-mono text-4xl font-bold tracking-tight text-console-bright sm:text-5xl">
      {identity.name}
    </h1>
    <p class="mt-3 font-mono text-lg text-console-cyan">
      {identity.title} · {identity.focus}
    </p>
    <p class="mt-6 max-w-xl text-base leading-relaxed text-console-text">
      {identity.summary}
    </p>

    <div class="mt-8 flex flex-wrap gap-3 font-mono text-sm">
      <a
        href={`mailto:${identity.email}`}
        class="border border-console-green bg-console-green/10 px-4 py-2 text-console-green no-underline transition-colors hover:bg-console-green/20"
      >
        ./contact --email
      </a>
      <a
        href={identity.github}
        class="border border-console-line px-4 py-2 text-console-text no-underline transition-colors hover:border-console-green hover:text-console-green"
      >
        github
      </a>
      <a
        href={identity.linkedin}
        class="border border-console-line px-4 py-2 text-console-text no-underline transition-colors hover:border-console-green hover:text-console-green"
      >
        linkedin
      </a>
      <a
        href={`${base}Saiteja_Garlapati_Resume.pdf`}
        class="border border-console-line px-4 py-2 text-console-text no-underline transition-colors hover:border-console-green hover:text-console-green"
      >
        resume.pdf ↓
      </a>
    </div>
  </div>

  <!-- Spec block: terminal window rendering the engineer as a K8s resource -->
  <div class="overflow-hidden border border-console-line bg-console-raised shadow-[0_0_60px_-20px_rgba(63,224,129,0.25)]">
    <!-- window chrome -->
    <div class="flex items-center gap-2 border-b border-console-line px-4 py-2.5" aria-hidden="true">
      <span class="h-2.5 w-2.5 rounded-full bg-console-line"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-console-line"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-console-line"></span>
      <span class="ml-2 font-mono text-xs text-console-dim">engineer.yaml</span>
    </div>

    <pre
      class="overflow-x-auto p-4 font-mono text-[13px] leading-relaxed sm:p-5"><code><span class="text-console-dim">apiVersion:</span> <span class="text-console-text">infra.dev/v1</span>
<span class="text-console-dim">kind:</span> <span class="text-console-cyan">Engineer</span>
<span class="text-console-dim">metadata:</span>
  <span class="text-console-dim">name:</span> <span class="text-console-text">{identity.handle}</span>
  <span class="text-console-dim">location:</span> <span class="text-console-text">hillsboro-or</span>
<span class="text-console-dim">spec:</span>
  <span class="text-console-dim">languages:</span> <span class="text-console-text">[go, python]</span>
  <span class="text-console-dim">domain:</span> <span class="text-console-text">[bare-metal, gpu-compute, llm-inference]</span>
  <span class="text-console-dim">employer:</span> <span class="text-console-text">intel-corporation</span>
<span class="text-console-dim">status:</span>
  <span class="text-console-dim">phase:</span> <span class="text-console-green">Ready</span> <span class="status-dot ml-1 inline-block h-2 w-2 rounded-full bg-console-green align-middle" aria-hidden="true"></span>
  <span class="text-console-dim">uptime:</span> <span class="text-console-text" id="uptime" data-since={identity.readySince}>since 2023-09-18</span>
  <span class="text-console-dim">conditions:</span>
    <span class="text-console-dim">- type:</span> <span class="text-console-text">BuildingControlPlanes</span>
      <span class="text-console-dim">status:</span> <span class="text-console-green">"True"</span>
    <span class="text-console-dim">- type:</span> <span class="text-console-text">ServingLLMs</span>
      <span class="text-console-dim">status:</span> <span class="text-console-green">"True"</span><span class="cursor-blink text-console-green" aria-hidden="true">▊</span></code></pre>
  </div>
</section>

<!-- Live uptime since the current role started. Falls back to the static
     server-rendered text without JS or with reduced motion. -->
<script>
  const el = document.getElementById("uptime");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (el?.dataset.since) {
    const since = new Date(el.dataset.since).getTime();

    const render = () => {
      let s = Math.max(0, Math.floor((Date.now() - since) / 1000));
      const d = Math.floor(s / 86400);
      s -= d * 86400;
      const h = Math.floor(s / 3600);
      s -= h * 3600;
      const m = Math.floor(s / 60);
      s -= m * 60;
      el.textContent = `${d}d ${h}h ${m}m ${String(s).padStart(2, "0")}s`;
    };

    render();
    // Only tick when motion is welcome; a static duration is still accurate.
    if (!reduced) setInterval(render, 1000);
  }
</script>
