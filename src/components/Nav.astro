---
/**
 * Fixed top nav, styled as a console title bar. Anchor links only —
 * the whole site is one page.
 */
import { identity } from "../data/resume";

const links = [
  { href: "#systems", label: "systems" },
  { href: "#lifecycle", label: "lifecycle" },
  { href: "#labels", label: "labels" },
  { href: "#contact", label: "contact" },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-console-line bg-console-bg/85 backdrop-blur">
  <nav
    aria-label="Main"
    class="mx-auto flex h-14 max-w-6xl items-center justify-between px-5 font-mono text-sm"
  >
    <a href="#top" class="shrink-0 text-console-bright no-underline hover:text-console-green">
      <span class="text-console-green">~/</span><span class="sm:hidden">sg</span><span
        class="hidden sm:inline">{identity.handle}</span>
    </a>

    <ul class="flex items-center gap-3 text-xs sm:gap-6 sm:text-sm">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="text-console-dim no-underline transition-colors hover:text-console-green"
            >
              <span class="hidden text-console-dim/50 sm:inline">./</span>{label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
